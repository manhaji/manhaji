# Manhaj ETL environment variables — copy to .env (gitignored) and fill in.
# Used by: etl/load_to_postgres.py, etl/seed_messages.py, etl/upload_source_to_supabase.py

# ============================================================================
# Supabase — project URL + service role key
# ============================================================================
# Get both from: Supabase Dashboard → Project Settings → API
#   SUPABASE_URL      = "Project URL"   (looks like https://xxxx.supabase.co)
#   SUPABASE_SERVICE_ROLE_KEY = "service_role" secret key (click Reveal to see it)
#
# The service role key bypasses RLS — never commit it, never paste it in chat.
# Keep it only in this .env file and in your hosting platform's encrypted secrets.
SUPABASE_URL=https://###############.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_publishable_############################

# ============================================================================
# Optional overrides
# ============================================================================
# Path to the school timetable workbook (default = data/source/...)
# XLSX_PATH=/absolute/path/to/timetable.xlsx

# School name (must match the row in the `schools` table)
# SCHOOL_NAME=International School of Oman

# Academic year label (must match `academic_years.label`)
# ACADEMIC_YEAR_LABEL=2026-2027
