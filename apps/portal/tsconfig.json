{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@manhaj/lib": ["../../packages/lib/src/index.ts"],
      "@manhaj/lib/*": ["../../packages/lib/src/*"],
      "@manhaj/ui": ["../../packages/ui/src/index.ts"],
      "@manhaj/ui/*": ["../../packages/ui/src/*"],
      "@manhaj/auth": ["../../packages/auth/src/index.ts"],
      "@manhaj/auth/*": ["../../packages/auth/src/*"],
      "@manhaj/admin": ["../admin/app"],
      "@manhaj/admin/*": ["../admin/*"],
      "@manhaj/teacher": ["../teacher/app"],
      "@manhaj/teacher/*": ["../teacher/*"],
      "@manhaj/student": ["../student/app"],
      "@manhaj/student/*": ["../student/*"],
      "@manhaj/parent": ["../parent/app"],
      "@manhaj/parent/*": ["../parent/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
