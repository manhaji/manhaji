# Manhaj Portal — environment variables
# Copy to .env.local and fill in.

# ============================================================================
# Session signing — iron-session
# ============================================================================
# Generate with: openssl rand -base64 32
# Must be at least 32 characters. Never commit the real value.
SESSION_SECRET=6L+Jz84pkLuVIXqSMV23ODHrzRqhJOloGj5s/QvULng=

# ============================================================================
# Demo passwords (one per role)
# ============================================================================
# These are the access codes shown to demo users. Keep them lowercase.
DEMO_PASSWORD_ADMIN=manhaj-admin
DEMO_PASSWORD_TEACHER=manhaj-teacher
DEMO_PASSWORD_STUDENT=manhaj-student
DEMO_PASSWORD_PARENT=manhaj-parent

# ============================================================================
# Supabase — server-only (not exposed to browser)
# ============================================================================
SUPABASE_URL=https://dxrkbjftkfhlddqefmaq.supabase.co
SUPABASE_ANON_KEY=

# ============================================================================
# Anthropic — server-only (admin AI chat)
# ============================================================================
ANTHROPIC_API_KEY=

# ============================================================================
