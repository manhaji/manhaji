# Manhaj Next.js — environment variables
# Copy to .env.local (gitignored) and fill in.

# ============================================================================
# Supabase — public values (safe to expose in browser; relies on RLS for safety)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://dxrkbjftkfhlddqefmaq.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ============================================================================
# Anthropic — Claude API (used for the principal chat box on /admin)
# ============================================================================
# Get from: https://console.anthropic.com → Settings → API Keys → Create Key
# Server-only — never expose to browser. /api/chat reads this at request time.
# Enable prompt caching on your Anthropic account for ~85% cost savings.
ANTHROPIC_API_KEY=

# ============================================================================
# Public app config
# ============================================================================
NEXT_PUBLIC_APP_NAME=Manhaj
NEXT_PUBLIC_SCHOOL_NAME=International School of Oman
NEXT_PUBLIC_ACADEMIC_YEAR=2026-2027
