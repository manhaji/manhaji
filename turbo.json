{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "SUPABASE_URL",
        "SUPABASE_ANON_KEY",
        "ANTHROPIC_API_KEY",
        "APP_NAME",
        "SCHOOL_NAME",
        "ACADEMIC_YEAR",
        "SESSION_SECRET",
        "DEMO_PASSWORD_ADMIN",
        "DEMO_PASSWORD_TEACHER",
        "DEMO_PASSWORD_STUDENT",
        "DEMO_PASSWORD_PARENT"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    }
  }
}
